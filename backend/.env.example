# Environment Configuration - Copy to .env and update values

# Application
APP_NAME=BiasGuard Bias Detection API
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# File Upload
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=uploads

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "*"]

# Data Processing
MISSING_VALUE_STRATEGY=fill
CATEGORICAL_THRESHOLD=10

# API
API_PREFIX=/api
API_TIMEOUT=30

# Logging
LOG_LEVEL=INFO
