# ==============================================================================
# ENVIRONMENT CONFIGURATION - Copy to .env and update values for your setup
# ==============================================================================
# This file lists all configurable environment variables for the backend API
# Default values are used if variables are not defined

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=Universal AI Bias Detection Tool
APP_VERSION=1.0.0
ENVIRONMENT=development
# Set to 'true' for development, 'false' for production
DEBUG=false

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=0.0.0.0
PORT=8000
# Number of worker processes for production deployments
WORKERS=4

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================
# Maximum upload size in MB
MAX_UPLOAD_SIZE_MB=100
# Directory where uploaded files will be stored
UPLOAD_DIR=uploads
# Hours to keep uploaded files before automatic cleanup
CLEANUP_UPLOADS_AFTER_HOURS=24

# =============================================================================
# DATA PROCESSING CONFIGURATION
# =============================================================================
# Strategy for handling missing values: 'drop' or 'fill'
MISSING_VALUE_STRATEGY=fill
# Threshold for determining if a feature is categorical (unique values count)
CATEGORICAL_THRESHOLD=10

# =============================================================================
# CORS CONFIGURATION
# =============================================================================
# Comma-separated list of allowed origins (no spaces)
# For development:
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000
# For production, specify exact domains:
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_PREFIX=/api
API_TIMEOUT=30

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=app.log
# Maximum log file size in bytes before rotation (10MB = 10485760)
LOG_MAX_BYTES=10485760
# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# =============================================================================
# BIAS CLASSIFICATION THRESHOLDS
# =============================================================================
# Bias scores between 0 and 1
# LOW bias: score < BIAS_THRESHOLD_LOW
# MEDIUM bias: BIAS_THRESHOLD_LOW <= score < BIAS_THRESHOLD_MEDIUM
# HIGH bias: score >= BIAS_THRESHOLD_MEDIUM
BIAS_THRESHOLD_LOW=0.1
BIAS_THRESHOLD_MEDIUM=0.3

# =============================================================================
# LLM CONFIGURATION (Google Generative AI / Gemini)
# =============================================================================
# Get your API key from: https://ai.google.dev/
# This enables AI-powered explanations of bias detection results
# Leave empty to disable LLM explanations (will use template-based fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# DATABASE CONFIGURATION (Optional, for future use)
# =============================================================================
# Uncomment and configure if using a database backend
# DATABASE_URL=postgresql://user:password@localhost:5432/biasguard
# REDIS_URL=redis://localhost:6379/0
